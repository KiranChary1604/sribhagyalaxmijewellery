{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/server.js"
    },
    {
      "source": "/admin-gate",
      "destination": "/api/server.js"
    },
    {
      "source": "/owner.html",
      "destination": "/api/server.js"
    },
    {
      "source": "/owner",
      "destination": "/api/server.js"
    },
    {
      "source": "/owner.js",
      "destination": "/api/server.js"
    }
  ]
}
